# GEMINI_API_KEY: Required for Emi (Choosify AI assistant) on the server — set in Vercel, never in VITE_*.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional Gemini model for Emi (defaults to gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"

# Catalog API used by Emi serverless function to ground answers
# CATALOG_API_BASE_URL="https://dashboard.choosify.bd/api/v1"

# Optional override for Emi chat endpoint (defaults to /api/emi/chat)
# VITE_EMI_API_URL="/api/emi/chat"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend catalog API base (for web/admin catalog sync)
# Local dev (admin API on port 3001): http://localhost:3001/api/v1
# Local dev (if proxied through storefront): http://localhost:3000/api/v1
# Production (Vercel): /api/v1 — proxied to dashboard.choosify.bd via vercel.json
VITE_API_BASE_URL="/api/v1"

# Google AdSense — create ad units in AdSense dashboard, paste slot IDs here
VITE_ADSENSE_CLIENT="ca-pub-3012630938814139"
VITE_ADSENSE_SLOT_SIDEBAR=""
VITE_ADSENSE_SLOT_INFEED=""
VITE_ADSENSE_SLOT_RESPONSIVE=""
