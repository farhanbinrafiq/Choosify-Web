{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=0, must-revalidate" 
        },
        { 
          "key": "Content-Type", 
          "value": "application/manifest+json" 
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=0, must-revalidate" 
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=31536000, immutable" 
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { 
          "key": "Cache-Control", 
          "value": "public, max-age=31536000, immutable" 
        }
      ]
    }
  ]
}
